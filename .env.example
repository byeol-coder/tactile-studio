# Copy this file to .env.local and replace placeholders with real values.
# Never commit real credentials.

# Public application configuration
VITE_APP_ENV=development

# Example API configuration
VITE_API_BASE_URL=https://api.example.com
VITE_API_KEY=replace_with_local_value

# Example Supabase configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace_with_local_value

# Server-only secrets must never use the VITE_ prefix.
# SERVER_API_KEY=replace_with_local_value
