{
  "name": "tactile-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Tactile Studio — migrating from a buildless x-dc CDN runtime to a React + Vite TypeScript monorepo (core/codecs/device/storage extracted; React editor shell in progress)",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "capture:baseline": "node tools/capture-baseline.mjs",
    "check:xdc-syntax": "node tools/check-xdc-syntax.mjs",
    "check:contrast": "node scripts/check-contrast.mjs",
    "capture:core-baseline": "node tools/capture-core-baseline.mjs",
    "capture:codecs-baseline": "node tools/capture-codecs-baseline.mjs",
    "capture:codecs-b-baseline": "node --experimental-strip-types tools/capture-codecs-b-baseline.mjs"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.6",
    "vitest": "^2.1.9"
  }
}
